{
  "name": "research-dark",
  "extends": "default",
  "palette": {
    "primary":   "E2E8F0",
    "accent":    "F59E0B",
    "text":      "CBD5E1",
    "muted":     "64748B",
    "bg":        "0F172A",
    "dark_bg":   "020617"
  },
  "watermark": {
    "enabled":  true,
    "type":     "image",
    "path":     "assets/logo.png",
    "position": "bottom-right",
    "opacity":  12,
    "w":        0.8,
    "h":        0.8,
    "margin":   0.2
  },
  "footer": {
    "enabled":  true,
    "left":     "{author}",
    "center":   "",
    "right":    "{n} / {total}",
    "fontSize": 8,
    "color":    "475569",
    "y":        5.32,
    "skip_slide_types": ["title", "closing"]
  },
  "title_slide":   { "bg": "dark_bg" },
  "section_slide": { "bg": "dark_bg" },
  "closing_slide": { "bg": "dark_bg" }
}
